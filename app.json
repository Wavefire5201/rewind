{
  "expo": {
    "name": "Rewind",
    "slug": "rewind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#1A1A1C",
    "scheme": "rewind",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rewind.app",
      "backgroundColor": "#1A1A1C",
      "infoPlist": {
        "NSCameraUsageDescription": "Rewind needs camera access to capture your daily photos.",
        "NSPhotoLibraryUsageDescription": "Rewind needs photo library access to set your profile avatar."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1A1C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "backgroundColor": "#1A1A1C",
      "package": "com.rewind.app",
      "permissions": ["CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      [
        "expo-camera",
        {
          "cameraPermission": "Rewind needs camera access to capture your daily photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Rewind needs photo library access to set your profile avatar."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Rewind to save photos and timelapses to your library.",
          "savePhotosPermission": "Allow Rewind to save photos and timelapses to your library."
        }
      ],
      "expo-document-picker"
    ]
  }
}
